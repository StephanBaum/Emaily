# =============================================================================
# Emaily — Root Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# All services (Next.js, workers, Prisma CLI) load from this single file.
# =============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL="postgresql://emaily:emaily@localhost:5432/emaily"

# --- Redis -------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Security ----------------------------------------------------------------
# 32-byte hex key for encrypting mailbox credentials at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# NextAuth v5 session secret.
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# --- AI Provider -------------------------------------------------------------
# "gemini" or "ollama" (auto-detected if omitted)
# AI_PROVIDER=""

# Google Gemini
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.5-flash"

# Local Ollama
# OLLAMA_HOST="http://localhost:11434"
# OLLAMA_MODEL="llama3.2"
# OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
