# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/emailclient"

# OpenAI API Key (for AI features)
OPENAI_API_KEY="sk-..."

# Auth.js v5 (NextAuth v5) Authentication
AUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (for Gmail API + Auth)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft/Azure OAuth (for Outlook)
# Create app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_TENANT_ID="common"

# Real-time Updates (Optional - for production scale with Google Pub/Sub)
# For Gmail push notifications - run: chmod +x scripts/setup-gmail-pubsub.sh && ./scripts/setup-gmail-pubsub.sh
# Documentation: docs/gmail-pubsub-setup.md
# Test setup: node scripts/test-gmail-watch.js
# GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"
# GMAIL_PUBSUB_TOPIC="gmail-notifications"
# GMAIL_PUBSUB_SUBSCRIPTION="gmail-notifications-sub"
# WEBHOOK_BASE_URL="https://your-domain.com"  # Required for production (must be publicly accessible HTTPS)
# PUBSUB_VERIFICATION_TOKEN="your-webhook-url"  # Usually your webhook URL: https://your-domain.com/api/webhooks/gmail

# Outlook Graph Subscriptions (for Outlook push notifications)
# For Outlook push notifications - run: chmod +x scripts/setup-outlook-subscriptions.sh && ./scripts/setup-outlook-subscriptions.sh
# Documentation: docs/outlook-subscriptions-setup.md
# Test setup: node scripts/test-outlook-subscription.js
# WEBHOOK_BASE_URL="https://your-domain.com"  # Required (must be publicly accessible HTTPS, same as Gmail)
# OUTLOOK_CLIENT_STATE="random-secret-string-min-32-chars"  # Generate with: openssl rand -hex 32
# Note: Outlook uses Microsoft Graph API subscriptions (no additional cloud infrastructure needed)

# Base URL (for OAuth callbacks)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# End-to-End Testing
# Test complete notification flow from email arrival to mobile device
# Run: node scripts/test-e2e-notification-flow.js
# Documentation: docs/e2e-notification-testing.md
# Prerequisites:
# - Gmail Pub/Sub OR Outlook Graph subscription configured
# - Mobile device registered with push token
# - Notification preferences enabled

# Notification Preferences Testing
# Test all notification preference modes and filtering logic
# Run: node scripts/test-notification-preferences.js
# Documentation: docs/notification-preferences-testing.md
# Tests:
# - Notifications disabled/enabled
# - Priority-only mode (filters low-priority emails)
# - Do-not-disturb hours (including overnight ranges)
# - All emails mode (no filtering)
