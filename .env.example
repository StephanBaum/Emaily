# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/emailclient"

# OpenAI API Key (for AI features)
OPENAI_API_KEY="sk-..."

# Auth.js v5 (NextAuth v5) Authentication
AUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (for Gmail API + Auth)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft/Azure OAuth (for Outlook)
# Create app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_TENANT_ID="common"

# Real-time Updates (Optional - for production scale with Google Pub/Sub)
# GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"

# Base URL (for OAuth callbacks)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Rate Limiting (Configured in code)
# Rate limits are hardcoded in apps/web/src/lib/rate-limit.ts
# Current limits:
# - Authentication endpoints: 5 requests per 15 minutes (brute force protection)
# - AI endpoints: 20 requests per minute (cost abuse prevention)
# - Email operations: 100 requests per minute (normal usage)
# - Email sync: 10 requests per 5 minutes (resource-intensive operations)
# To modify limits, edit the RATE_LIMITS constant in apps/web/src/lib/rate-limit.ts
