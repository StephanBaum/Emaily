// packages/database/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Auth.js v5 Models (required for PrismaAdapter)
// ============================================

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  emailVerified DateTime? // Auth.js field
  name          String?
  image         String? // Auth.js field
  accounts      Account[] // Auth.js OAuth accounts
  sessions      Session[] // Auth.js sessions
  emailAccounts EmailAccount[] // Email provider connections
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Application Models
// ============================================

model EmailAccount {
  id       String @id @default(cuid())
  provider String // "gmail" | "outlook" | "imap"

  // OAuth fields (for gmail, outlook)
  accessToken  String? @db.Text
  refreshToken String? @db.Text

  // IMAP-specific fields (for imap provider)
  email             String? // User's email address for IMAP
  encryptedPassword String?  @db.Text // AES-256 encrypted password
  imapHost          String? // IMAP server hostname
  imapPort          Int? // IMAP port (993 or 143)
  imapSecure        Boolean? // true for TLS, false for STARTTLS
  smtpHost          String? // SMTP server hostname
  smtpPort          Int? // SMTP port (587 or 465)
  smtpSecure        Boolean? // true for port 465, false for STARTTLS

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails    Email[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Email {
  id         String       @id @default(cuid())
  messageId  String       @unique
  threadId   String?
  subject    String
  sender     String
  recipients String[]
  body       String
  bodyHtml   String?
  isRead     Boolean      @default(false)
  isStarred  Boolean      @default(false)
  category   String? // AI-determined category
  priority   Int? // AI-determined priority (1-5)
  summary    String? // AI-generated summary
  accountId  String
  account    EmailAccount @relation(fields: [accountId], references: [id])
  receivedAt DateTime
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([accountId, receivedAt])
  @@index([category])
}
